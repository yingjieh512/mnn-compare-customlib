build customlib/libxqwen35.dll customlib/libxqwen35.dll.a: CXX_SHARED_LIBRARY_LINKER__xqwen35_ customlib/CMakeFiles/xqwen35.dir/runtime/session.cpp.obj customlib/CMakeFiles/xqwen35.dir/runtime/tokenizer_bridge.cpp.obj customlib/CMakeFiles/xqwen35.dir/runtime/sampler.cpp.obj customlib/CMakeFiles/xqwen35.dir/runtime/cache_manager.cpp.obj customlib/CMakeFiles/xqwen35.dir/runtime/telemetry.cpp.obj customlib/CMakeFiles/xqwen35.dir/runtime/custom_model.cpp.obj customlib/CMakeFiles/xqwen35.dir/mnn_bridge/mnn_loader.cpp.obj customlib/CMakeFiles/xqwen35.dir/mnn_bridge/graph_rewrite.cpp.obj customlib/CMakeFiles/xqwen35.dir/mnn_bridge/custom_op_registry.cpp.obj customlib/CMakeFiles/xqwen35.dir/mnn_bridge/xqwen_linear_execution.cpp.obj customlib/CMakeFiles/xqwen35.dir/mnn_bridge/xqwen_rmsnorm_execution.cpp.obj customlib/CMakeFiles/xqwen35.dir/mnn_bridge/xqwen_rope_execution.cpp.obj customlib/CMakeFiles/xqwen35.dir/mnn_bridge/xqwen_attention_execution.cpp.obj customlib/CMakeFiles/xqwen35.dir/mnn_bridge/xqwen_delta_execution.cpp.obj customlib/CMakeFiles/xqwen35.dir/mnn_bridge/xqwen_ffn_execution.cpp.obj customlib/CMakeFiles/xqwen35.dir/kernels/reference/ref_gemv.cpp.obj customlib/CMakeFiles/xqwen35.dir/kernels/reference/ref_rmsnorm.cpp.obj customlib/CMakeFiles/xqwen35.dir/kernels/reference/ref_rope.cpp.obj customlib/CMakeFiles/xqwen35.dir/kernels/reference/ref_attention.cpp.obj customlib/CMakeFiles/xqwen35.dir/kernels/reference/ref_delta.cpp.obj customlib/CMakeFiles/xqwen35.dir/kernels/generated/generated_dispatch.cpp.obj customlib/CMakeFiles/xqwen35.dir/kernels/generated/arm64_neon/xq_gemv_w4a16_neon.cpp.obj customlib/CMakeFiles/xqwen35.dir/kernels/generated/arm64_neon/xq_gemv_w3a16_neon.cpp.obj customlib/CMakeFiles/xqwen35.dir/kernels/generated/arm64_neon/xq_gemv_w2a16_neon.cpp.obj
  LINK_FLAGS = -shared
  LINK_LIBRARIES = -lkernel32 -luser32 -lgdi32 -lwinspool -lshell32 -lole32 -loleaut32 -luuid -lcomdlg32 -ladvapi32
  OBJECT_DIR = customlib\CMakeFiles\xqwen35.dir
  POST_BUILD = cd .
  PRE_LINK = cd .
  RESTAT = 1
  TARGET_FILE = customlib\libxqwen35.dll
  TARGET_IMPLIB = customlib\libxqwen35.dll.a
  TARGET_PDB = xqwen35.dll.dbg
  TARGET_SUPPORT_DIR = customlib\CMakeFiles\xqwen35.dir


